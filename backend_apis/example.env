##############################################
# MQTT Gateway API - Backend configuration
# File: backend_apis/.env
##############################################

########################
# App / Logging
########################
APP_NAME=MQTT Gateway API
APP_LOG_LEVEL=INFO

########################
# Security (UI Settings PIN)
########################
# If set, the frontend must verify this PIN via POST /settings/verify-pin
# before showing the Settings page. If empty/not set, Settings are accessible.
SETTINGS_PIN=1234

########################
# Database (Postgres)
########################
# Used for:
# - Settings persistence (system_settings table)
# - Device presets
#
# If you already run Postgres with different credentials/host, set these.
# DB_USER=postgres
# DB_PASSWORD=postgres
# DB_HOST=localhost
# DB_PORT=5432
# DB_NAME=tb_setup_db

########################
# MQTT Broker
########################
MQTT_HOST=localhost
MQTT_PORT=1883
MQTT_USERNAME=
MQTT_PASSWORD=
MQTT_CLIENT_ID_PREFIX=gateway_service
MQTT_KEEPALIVE=60
MQTT_TOPIC_PATTERN=FM/#
MQTT_QOS=1

########################
# ThingsBoard / Antar IoT - Push (Realtime)
########################
# Base URL of ThingsBoard
THINGSBOARD_BASE_URL=http://192.168.0.253:8080

# Enable pushing telemetry to ThingsBoard
ENABLE_TELEMETRY_PUSH=true

# If true, publish automatically when MQTT message arrives
ENABLE_AUTO_TELEMETRY_PUSH=true

# HTTP timeout for push requests (seconds)
TELEMETRY_TIMEOUT_SECONDS=5.0

# Device token strategy:
# - If ONE_DEVICE_PER_METER=true:
#   each meter is a separate ThingsBoard device and its ACCESS TOKEN should match
#   the meter id (11A, 11B, 11C, ...). No UUIDs needed for push.
# - If ONE_DEVICE_PER_METER=false:
#   you can optionally set a single token for all telemetry using THINGSBOARD_DEVICE_TOKEN.
THINGSBOARD_DEVICE_TOKEN=
THINGSBOARD_TOKEN_FROM_TOPIC_REGEX=
ONE_DEVICE_PER_METER=true

# Periodic push (seconds):
# 0 = push only when MQTT message arrives
TELEMETRY_PUSH_INTERVAL_SECONDS=0

########################
# Inactivity (Realtime "Inactive" state)
########################
# If > 0, backend can set ThingsBoard device inactivity timeout so device state flips to
# Inactive soon after MQTT stops. Uses ThingsBoard download credentials + device UUIDs
# (THINGSBOARD_DEVICE_ID / THINGSBOARD_DEVICE_IDS) to patch server attributes.
TELEMETRY_INACTIVITY_TIMEOUT_SECONDS=60
# TELEMETRY_INACTIVITY_MINUTES=5
# TELEMETRY_INACTIVITY_CHECK_INTERVAL_SECONDS=60

########################
# ThingsBoard - Download / Reports (Historical)
########################
# Credentials for downloading historical telemetry.
THINGSBOARD_USERNAME=tenant@antariiot.com
THINGSBOARD_PASSWORD=tenant

# Devices for download/report generation:
# - Single device UUID:
THINGSBOARD_DEVICE_ID=
# - Multiple device UUIDs (comma-separated):
THINGSBOARD_DEVICE_IDS=

# Download timeout (seconds)
# THINGSBOARD_DOWNLOAD_TIMEOUT_SECONDS=30.0