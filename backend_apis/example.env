##############################################
# MQTT Gateway API - Example configuration
# Copy to: backend_apis/.env
#
# Notes:
# - Values here are safe placeholders.
# - Real secrets (passwords, PIN) should not be committed.
# - Settings in DB (via /settings) override many of these env values.
##############################################

########################
# App / Logging
########################
APP_NAME=MQTT Gateway API
APP_LOG_LEVEL=INFO

########################
# Security (UI Settings PIN)
########################
# If set, the UI must verify this PIN before opening the Settings page.
# Leave empty to disable PIN protection.
# SETTINGS_PIN=1234

########################
# Database (Postgres)
########################
# Used for Settings persistence + Device presets.
DB_USER=postgres
DB_PASSWORD=postgres
DB_HOST=localhost
DB_PORT=5432
DB_NAME=tb_setup_db

########################
# MQTT Broker
########################
MQTT_HOST=localhost
MQTT_PORT=1883
MQTT_USERNAME=
MQTT_PASSWORD=
MQTT_CLIENT_ID_PREFIX=gateway_service
MQTT_KEEPALIVE=60
# Example: subscribe only FM gateways
MQTT_TOPIC_PATTERN=FM/#
MQTT_QOS=1

########################
# ThingsBoard / Antar IoT - Common base URL
########################
# Used for both Push and Download (unless DB overrides download base URL)
THINGSBOARD_BASE_URL=http://192.168.0.253:8080

########################
# ThingsBoard / Antar IoT - Push (Realtime)
########################
ENABLE_TELEMETRY_PUSH=true
ENABLE_AUTO_TELEMETRY_PUSH=true
TELEMETRY_TIMEOUT_SECONDS=5.0

# Token strategy (optional):
# - If ONE_DEVICE_PER_METER=true: each meter is a separate TB device and its ACCESS TOKEN
#   should match meter id (11A, 11B, ...). You typically leave these empty.
# - If ONE_DEVICE_PER_METER=false: you may use a single device token for all telemetry.
THINGSBOARD_DEVICE_TOKEN=
THINGSBOARD_TOKEN_FROM_TOPIC_REGEX=
ONE_DEVICE_PER_METER=true

# Periodic push (seconds). 0 = push only when MQTT message arrives.
TELEMETRY_PUSH_INTERVAL_SECONDS=0

########################
# Inactivity (Realtime "Inactive" state)
########################
# If > 0, backend can set TB inactivityTimeout server attribute on startup.
# Requires download credentials + device UUID(s) below.
TELEMETRY_INACTIVITY_TIMEOUT_SECONDS=60

# Optional (only used by periodic push skip logic):
# TELEMETRY_INACTIVITY_MINUTES=5
# TELEMETRY_INACTIVITY_CHECK_INTERVAL_SECONDS=60

########################
# ThingsBoard - Download / Reports (Historical)
########################
# Used by:
# - /download/thingsboard
# - /reports/* endpoints (daily consumption + CSV)
THINGSBOARD_USERNAME=tenant@example.com
THINGSBOARD_PASSWORD=CHANGE_ME

# Devices for download/report generation:
# IMPORTANT: these must be real ThingsBoard device UUIDs (Device -> Details -> Copy ID)
THINGSBOARD_DEVICE_ID=
THINGSBOARD_DEVICE_IDS=00000000-0000-0000-0000-000000000000,11111111-1111-1111-1111-111111111111

# Download timeout (seconds)
THINGSBOARD_DOWNLOAD_TIMEOUT_SECONDS=30.0

